{
  "name": "@word-kit/core",
  "version": "0.0.0",
  "description": "OOXML-compliant .docx generation for browser and Node.js.",
  "keywords": [
    "docx",
    "ecma-376",
    "ooxml",
    "word",
    "wordprocessingml"
  ],
  "homepage": "https://github.com/baseballyama/word-kit#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/word-kit/issues"
  },
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/word-kit.git",
    "directory": "packages/core"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@word-kit/ooxml-xml": "workspace:*",
    "@word-kit/opc": "workspace:*",
    "@word-kit/wml": "workspace:*"
  },
  "engines": {
    "node": ">=20"
  }
}
