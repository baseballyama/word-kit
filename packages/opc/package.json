{
  "name": "@word-kit/opc",
  "version": "0.0.0",
  "description": "Open Packaging Conventions (OPC) layer used by word-kit. Internal.",
  "keywords": [
    "ecma-376",
    "ooxml",
    "opc"
  ],
  "homepage": "https://github.com/baseballyama/word-kit#readme",
  "bugs": {
    "url": "https://github.com/baseballyama/word-kit/issues"
  },
  "license": "MIT",
  "author": "Yuichiro Yamashita",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/baseballyama/word-kit.git",
    "directory": "packages/opc"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json"
  },
  "engines": {
    "node": ">=20"
  }
}
