{
  "name": "word-kit-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && pagefind --site build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch"
  },
  "dependencies": {
    "@word-kit/core": "workspace:*",
    "@word-kit/preview": "workspace:*"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@types/node": "^22.10.0",
    "mdsvex": "^0.12.7",
    "pagefind": "^1.5.2",
    "shiki": "^4.0.2",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "^5.7.0",
    "vite": "^8.0.11"
  }
}
